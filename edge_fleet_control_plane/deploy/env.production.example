# Production environment for Tapis pod: edgecontrolplane
# Copy to deploy/env.production, fill secrets, then load into the pod spec.

APP_ENV=production
APP_DEBUG=false
APP_SECRET=REPLACE_WITH_openssl_rand_hex_32
APP_BASE_URL=https://edgecontrolplane.pods.icicleai.tapis.io

# Postgres — use split vars on Tapis pods (each value must be <= 128 chars)
DB_HOST=edgetoolsuitedb.pods.icicleai.tapis.io
DB_PORT=443
# Use 443 for pod-to-pod on Tapis (5432 often times out). Direct 5432 may work outside the cluster.
DB_USER=edgetoolsuitedbuser
DB_PASSWORD=REPLACE_DB_PASSWORD
DB_NAME=edgetoolsuitedbuser
DB_SSLMODE=require
# Or a single DATABASE_URL for local/docker-compose (can exceed 128 chars)
# DATABASE_URL=postgresql://user:pass@host:5432/dbname?sslmode=require

# SQLite fallback for local dev when DB_HOST is unset
DATABASE_PATH=data/edge_control_plane.db

LOCAL_DEV_AUTH=false
ALLOW_LOCALHOST_INSTALLER=false

# Tapis OAuth — register callback https://edgecontrolplane.pods.icicleai.tapis.io/auth/callback
TAPIS_BASE_URL=https://icicleai.tapis.io
TAPIS_CLIENT_ID=icicle-edge-control-plane
TAPIS_CLIENT_KEY=REPLACE_TAPIS_CLIENT_KEY
TAPIS_ADMIN_USERNAMES=habg21

# Iframe SSO from Tapis UI (comma-separated parent origins)
TAPIS_PORTAL_ORIGINS=http://localhost:3000,https://icicleai.tapis.io
# Required for session cookies inside Tapis UI iframes (HTTPS prod)
SESSION_SAME_SITE=none

HEARTBEAT_INTERVAL_SECONDS=30
DEVICE_OFFLINE_AFTER_SECONDS=120
OFFLINE_MONITOR_INTERVAL_SECONDS=30
HEARTBEAT_HISTORY_MODE=none
HEARTBEAT_HISTORY_RETENTION_HOURS=24
HEARTBEAT_STORE_PAYLOAD=false

MQTT_ENABLED=true
MQTT_HOST=icicleedgemqttbroker.pods.icicleai.tapis.io
MQTT_PORT=443
MQTT_TLS=true
MQTT_BASE_TOPIC=icicle/v1
# Omit MQTT_USERNAME / MQTT_PASSWORD if your broker allows anonymous access
MQTT_CLIENT_ID_PREFIX=icicle-control-plane

PATRA_BASE_URL=https://patrabackend.pods.icicleai.tapis.io

# Live camera streaming — see deploy/STREAMING.md
# Mode is auto-selected:
#   * relay (default): device pushes MJPEG over HTTPS to APP_BASE_URL, browser
#     plays /devices/{id}/stream.mjpg. No extra pods/ports.
#   * mediamtx: set MEDIA_INGEST_URL + MEDIA_HLS_BASE_URL below to switch to the
#     two-pod MediaMTX path (H.264/RTSPS in, HLS out). See deploy/mediamtx/.
MEDIA_ENABLED=true
MEDIA_STREAM_PREFIX=cam
MEDIA_DEFAULT_CAMERA=csi
MEDIA_DEFAULT_WIDTH=1280
MEDIA_DEFAULT_HEIGHT=720
MEDIA_DEFAULT_FPS=15
MEDIA_JPEG_QUALITY=80
MEDIA_DEFAULT_BITRATE_KBPS=2000
# Ingest token lifetime (seconds) and how long after the last frame a device is
# still considered "live" (relay mode).
MEDIA_TOKEN_TTL_SECONDS=86400
MEDIA_LIVE_AFTER_SECONDS=12
# --- MediaMTX mode (required for inference live streams + device HLS test stream) ---
MEDIA_INGEST_URL=rtsps://edgemediaingest.pods.icicleai.tapis.io:443
MEDIA_HLS_BASE_URL=https://edgemediahls.pods.icicleai.tapis.io
