[Unit]
Description=ICICLE Edge Agent
After=network-online.target docker.service
Wants=network-online.target

[Service]
Type=simple
WorkingDirectory=/opt/icicle-edge/agent
ExecStart=/usr/bin/python3 /opt/icicle-edge/agent/main.py
Restart=always
RestartSec=5
User=root

[Install]
WantedBy=multi-user.target
