APP_ENV=development
APP_DEBUG=true
APP_SECRET=dev-change-me
APP_BASE_URL=http://localhost:8000

# SQLite (local dev) — leave DATABASE_URL empty
DATABASE_PATH=data/edge_control_plane.db
# PostgreSQL (production pod) — split vars fit Tapis 128-char env limit
# DB_HOST=edgetoolsuitedb.pods.icicleai.tapis.io
# DB_PORT=5432
# DB_USER=edgetoolsuitedbuser
# DB_PASSWORD=...
# DB_NAME=edgetoolsuitedbuser
# DB_SSLMODE=require
# Or use DATABASE_URL locally when not limited to 128 chars

LOCAL_DEV_AUTH=true
LOCAL_DEV_USERNAME=local_tapis_user

# Tapis OAuth (set LOCAL_DEV_AUTH=false to enable)
TAPIS_BASE_URL=https://icicleai.tapis.io
TAPIS_CLIENT_ID=
TAPIS_CLIENT_KEY=
# Defaults to ${APP_BASE_URL}/auth/callback — must match OAuth client callback_url
TAPIS_CALLBACK_URL=
# Comma-separated Tapis usernames promoted to admin on login
TAPIS_ADMIN_USERNAMES=

HEARTBEAT_INTERVAL_SECONDS=30
DEVICE_OFFLINE_AFTER_SECONDS=120
OFFLINE_MONITOR_INTERVAL_SECONDS=30

# Heartbeat history in device_heartbeats (devices.last_heartbeat_at always updated)
# mode: none | sample | all
#   none   — no history rows (best for Postgres; online/offline still works)
#   sample — one history row per device every N seconds (default, good for UI sparkline)
#   all    — every heartbeat persisted (dev/debug only)
HEARTBEAT_HISTORY_MODE=sample
HEARTBEAT_HISTORY_SAMPLE_SECONDS=300
HEARTBEAT_HISTORY_RETENTION_HOURS=48
HEARTBEAT_STORE_PAYLOAD=false

# Set true only for local smoke tests.
ALLOW_LOCALHOST_INSTALLER=false

# MQTT
MQTT_ENABLED=false
MQTT_HOST=icicleedgemqttbroker.pods.icicleai.tapis.io
MQTT_PORT=443
MQTT_TLS=true
MQTT_BASE_TOPIC=icicle/v1
MQTT_USERNAME=
MQTT_PASSWORD=
MQTT_CLIENT_ID_PREFIX=icicle-control-plane

# Patra (model artifact resolution)
PATRA_BASE_URL=https://patrabackend.pods.icicleai.tapis.io

# Live camera streaming — see deploy/STREAMING.md
# Mode auto-selects: relay (MJPEG over HTTPS, no extra infra) by default, or
# mediamtx (H.264/RTSPS in, HLS out) when MEDIA_INGEST_URL + MEDIA_HLS_BASE_URL
# are set (two-pod MediaMTX deployment, see deploy/mediamtx/).
MEDIA_ENABLED=false
MEDIA_STREAM_PREFIX=cam
# Default camera capture on the device: csi (nvarguscamerasrc) or usb (v4l2)
MEDIA_DEFAULT_CAMERA=csi
MEDIA_DEFAULT_WIDTH=1280
MEDIA_DEFAULT_HEIGHT=720
MEDIA_DEFAULT_FPS=15
MEDIA_JPEG_QUALITY=80
MEDIA_DEFAULT_BITRATE_KBPS=2000
MEDIA_TOKEN_TTL_SECONDS=86400
MEDIA_LIVE_AFTER_SECONDS=12
# --- MediaMTX mode (leave blank to use the built-in relay) ---
# MEDIA_INGEST_URL=rtsps://edgemediaingest.pods.icicleai.tapis.io:443
# MEDIA_HLS_BASE_URL=https://edgemediahls.pods.icicleai.tapis.io

# Optional CORS for the JSON API
CORS_ORIGINS=
